<!DOCTYPE html>
<html lang="en" prefix="zotero: http://www.zotero.org/namespaces/export#">
<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>{% block title %}{{ title }} - {{ site.title }}{% endblock %}</title>
  <meta name="generator" content="{{ eleventy.generator }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="/images/favicon/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/images/favicon/favicon.svg" />
  <link rel="shortcut icon" href="/images/favicon/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Steven Newcomb" />
  <link rel="manifest" href="/images/favicon/site.webmanifest" />
  {% if canonical_url %}
    <link rel="canonical" href="{{ canonical_url }}" />
  {% else %}
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
    {% seo "" %}
  {% endif %}
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }} Atom Feed" href="{{ site.url }}/feed/feed.xml" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS Feed" href="{{ site.url }}/feed/rss.xml" />

  <link rel="stylesheet" href="/scss/style.css">

  {% include "schema.njk" %}
  {% block meta_tags %}
    {% if description %}<meta name="description" content="{{ description }}"/>{% endif %}
    <meta property="og:title" content="{{ title }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ site.url }}{{ page.url }}"/>
    {% if image %}<meta property="og:image" content="{{ site.url }}{{ image }}"/>{% endif %}
    {% if description %}<meta property="og:description" content="{{ description }}"/>{% endif %}
    <meta name="twitter:card" content="summary"/>
    {% if site.twitter %}<meta name="twitter:site" content="{{ site.twitter }}"/>{% endif %}
    {% if site.twitter %}<meta name="twitter:creator" content="{{ site.twitter }}"/>{% endif %}
  {% endblock %}

  {% if site.enableGoogleFonts %}
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="{{ site.googleFontsUrl }}" rel="stylesheet" preconnect>
  {% endif %}

  {# Zotero / Highwire / PRISM — makes posts harvestable as Blog Post type #}
  {% set isPost = layout == 'post' %}
  {% if isPost %}
  <meta property="zotero:itemType" content="blogPost" />
  <meta property="dc:title" content="{{ title | escape }}" />
  <meta property="dc:creator" content="{{ site.author | escape }}" />
  {% if date %}<meta property="dc:date" content="{{ date | date('Y-m-d') }}" />{% endif %}
  <meta property="dc:language" content="en" />
  <meta property="dc:identifier" content="{{ site.url }}{{ page.url }}" />
  <meta name="citation_author" content="{{ site.author | escape }}" />
  {% if date %}<meta name="citation_publication_date" content="{{ date | date('Y-m-d') }}" />{% endif %}
  <meta name="citation_public_url" content="{{ site.url }}{{ page.url }}" />
  <meta name="citation_language" content="en" />
  {% if doi %}<meta name="citation_doi" content="{{ doi | escape }}" />{% endif %}
  <meta name="prism.genre" content="blogentry" />
  <meta name="prism.publicationName" content="Steven T. Newcomb" />
  {% endif %}
</head>

<body class='page{% if site.addFrame %} frame{% endif %} {% block body_classes %}{% endblock %}' role="document">
  {% include "mobile-menu.njk" %}
  <div id="wrapper" class="wrapper">
    {% include "header.njk" %}
    <main role="main">
    {% block main %}
    {% endblock %}
    </main>
    <!-- outputs all the icons used on the page -->
    {% getBundle "fontawesome" %}
    {% include "footer.njk" %}
  </div>
  <script type="text/javascript" src="/js/scripts.js"></script>

  {% block footer_js %}
  {% endblock %}
</body>
</html>
